# Packwiz generates TOML files with LF line endings
# Force LF for these files to prevent spurious diffs on Windows
*.pw.toml   text eol=lf
pack.toml   text eol=lf
index.toml  text eol=lf
# Binary files - never modify line endings
*.jar       binary
*.zip       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.exe       binary
*.dll       binary
*.so        binary
*.dylib     binary
sunlit_valley/mods/species-3.5.jar filter=lfs diff=lfs merge=lfs -text
