# Auto detect text files and normalize line endings to LF on commit
* text=auto

# Explicitly declare text files to always be normalized and converted to LF
*.md        text eol=lf
*.toml      text eol=lf
*.pw.toml   text eol=lf
*.json      text eol=lf
*.snbt      text eol=lf
*.js        text eol=lf
*.lang      text eol=lf
*.properties text eol=lf
*.log       text eol=lf
*.data      text eol=lf
*.config    text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.xml       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.rs        text eol=lf

# Binary files - never modify line endings
*.jar       binary
*.zip       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.exe       binary
*.dll       binary
*.so        binary
*.dylib     binary
